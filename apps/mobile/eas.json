{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_SKIP_NPM_INSTALL": "1",
        "EXPO_USE_PNPM": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_SKIP_NPM_INSTALL": "1",
        "EXPO_USE_PNPM": "1"
      }
    },
    "testflight": {
      "extends": "production",
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_SKIP_NPM_INSTALL": "1",
        "EXPO_USE_PNPM": "1"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "env": {
        "EXPO_SKIP_NPM_INSTALL": "1",
        "EXPO_USE_PNPM": "1"
      }
    }
  },
  "submit": {
    "testflight": {},
    "production": {}
  }
}
